# ── Hugging Face OAuth ─────────────────────────────────────────────────────────
AUTH_HUGGINGFACE_ID=
AUTH_HUGGINGFACE_SECRET=

# ── NextAuth ───────────────────────────────────────────────────────────────────
# For local dev: http://localhost:3001
# For Vercel:    https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3001
AUTH_SECRET=

# ── MongoDB (Atlas for production, local for dev) ──────────────────────────────
# Local:  mongodb://localhost:27017/deepsite
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/deepsite?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/deepsite

# ── AI Providers ───────────────────────────────────────────────────────────────
# Groq (free tier — used for vision, security review, and fast generation fallback)
GROQ_API_KEY=your_groq_key_here